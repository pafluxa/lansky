# Copy this file to .env and fill in your values.
# .env is never committed and never baked into the Docker image.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults shown
SQLITE_DB_PATH=/app/data/lansky.db
MODEL=anthropic:claude-sonnet-4-6
MCP_CODE_EXECUTOR_URL=http://code-executor:3333/mcp
ENABLE_THINKING=false
THINKING_BUDGET_TOKENS=5000

# LLM model for the extractor (llama-server)
# LLAMA_MODEL=Qwen/Qwen3-8B-GGUF:Q4_K_M
