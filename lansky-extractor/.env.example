IMAP_HOST=imap.mail.me.com
IMAP_USER=your@icloud.com
IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx
IMAP_FOLDER=INBOX
# Comma-separated list of bank notification sender addresses
BANK_SENDERS=alertas@bci.cl,notificaciones@bci.cl,alertas@bancochile.cl
# When running in Docker Compose (defaults, no need to change):
# LLM_BASE_URL=http://llm-server:8081/v1
# LANSKY_API_URL=http://lansky:8000
#
# When running bare on the host:
# LLM_BASE_URL=http://127.0.0.1:8081/v1
# LANSKY_API_URL=http://127.0.0.1:8000

LLM_BASE_URL=http://llm-server:8080/v1
LLM_MODEL=qwen3-8b
LANSKY_API_URL=http://lansky:8000
POLL_INTERVAL_SECONDS=900
LOG_LEVEL=INFO
